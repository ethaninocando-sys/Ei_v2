# Copy to .env.local and fill in with your own values.
# (.env.local is gitignored — never commit real keys.)

# --- Resend (contact form email) ------------------------------------------
# https://resend.com -> API Keys
RESEND_API_KEY=

# Verified sender on your domain once ei-conversion.com is verified in Resend,
# e.g. "Ei Conversion <hello@ei-conversion.com>".
# Until then the code falls back to Resend's shared onboarding@resend.dev sender,
# which only delivers to the Resend account owner's inbox.
RESEND_FROM=

# Where new inquiry notifications are sent (defaults to the address in
# src/lib/config.ts -> siteConfig.email).
INQUIRIES_TO=

# Resend Audience for newsletter signups ("3 free tips" form).
# Resend dashboard -> Audiences -> copy the Audience ID. If unset, signups
# still get the tips email — they just aren't added to a newsletter list.
RESEND_AUDIENCE_ID=

# --- Formspree (submission record / "database") ----------------------------
# Every inquiry-form and newsletter-signup submission is also POSTed here
# server-side, independent of Resend, so leads are never lost to an email
# misconfiguration. Defaults to the Ei Conversion form below if unset —
# override to point at a different Formspree form.
FORMSPREE_ENDPOINT=https://formspree.io/f/mbdvvavy
